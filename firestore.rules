rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /leaderboard/{document} {
      allow read: if true;
      allow create: if request.resource.data.username is string
                    && request.resource.data.username.size() > 0
                    && request.resource.data.username.size() <= 20
                    && request.resource.data.wpm is number
                    && request.resource.data.accuracy is number
                    && request.resource.data.mode is string
                    && request.resource.data.difficulty is string;
      allow update, delete: if false;
    }
  }
}
